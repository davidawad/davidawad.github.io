---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    /** Optional: path to the LLM-friendly version of this page (llms.txt).
     *  Set this in the markdown frontmatter of any page that has an llms.txt endpoint.
     *  Example:  llmUrl: /about/llms.txt */
    llmUrl?: string;
  };
}

const { frontmatter } = Astro.props;
const isRtl = Astro.url.pathname.startsWith("/ar");
---

<Layout title={`${frontmatter.title} | ${SITE.title}`} llmUrl={frontmatter.llmUrl}>
  <Header />
  <Breadcrumbs />
  <main id="main-content" class:list={["app-layout pb-12", { "text-right": isRtl }]}>
    <article class="app-prose max-w-3xl">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </article>
  </main>
  <Footer />
</Layout>
