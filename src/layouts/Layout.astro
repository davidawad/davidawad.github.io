---
import { ClientRouter } from "astro:transitions";
import { GoogleAnalytics } from "astro-google-analytics";
import { SITE } from "@config";
import "@styles/global.css";

const lang = Astro.url.pathname.startsWith("/ar") ? "ar" : "en";

export interface Props {
  title?: string;
  author?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
}

const {
  title = SITE.title,
  author = SITE.author,
  description = SITE.desc,
  ogImage = SITE.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
} = Astro.props;

const socialImageURL = new URL(
  ogImage ? ogImage : SITE.ogImage,
  Astro.url.origin
).href;
---

<!doctype html>
<html lang={lang} class={scrollSmooth ? "scroll-smooth" : ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: IBM Plex Mono (body), Abril Fatface (headings), Scheherazade New (Arabic) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Abril+Fatface&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Scheherazade+New&display=swap"
      rel="stylesheet"
    />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed for davidaw.ad"
      href="https://davidaw.ad/rss.xml"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <meta name="theme-color" content="" />

    {
      import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <!-- Prevent FOUC: set theme immediately before page renders -->
    <script is:inline>
      (function () {
        const primaryColorScheme = "";
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (primaryColorScheme) return primaryColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>

    <GoogleAnalytics id="G-B29WM3F6QJ" />
  </head>
  <body>
    <slot />
    <script src="../scripts/theme.ts"></script>
    <script is:inline data-astro-rerun>
      function applyTashkil() {
        if (document.documentElement.lang !== "ar") return;
        const main = document.getElementById("main-content");
        if (!main || main.dataset.tashkil === "1") return;

        // Wait for Kawkab Mono fonts to load before cloning, so both layers
        // use the same font metrics and produce identical line-breaking
        const kawkabFonts = [...document.fonts].filter(f =>
          f.family.includes("Kawkab Mono Base") || f.family.includes("Kawkab Mono Mark")
        );
        if (kawkabFonts.some(f => f.status !== "loaded")) {
          Promise.all(kawkabFonts.map(f => f.load())).then(applyTashkil);
          return;
        }

        main.dataset.tashkil = "1";

        // Wrap existing content in #tashkil-base (stays in normal flow, sizes main)
        const base = document.createElement("div");
        base.id = "tashkil-base";
        while (main.firstChild) base.appendChild(main.firstChild);
        main.appendChild(base);

        function buildMark() {
          const existing = document.getElementById("tashkil-mark");
          if (existing) existing.remove();

          const mark = base.cloneNode(true);
          mark.id = "tashkil-mark";
          mark.setAttribute("aria-hidden", "true");
          mark.style.cssText = "";
          mark.querySelectorAll("svg, img, video, canvas, iframe, button, input, select, textarea, script, style").forEach(el => {
            el.style.visibility = "hidden";
          });
          base.appendChild(mark);
        }

        // Append mark INSIDE base so it shares the exact same width/padding context
        base.style.position = "relative";
        buildMark();

        // Re-clone mark after KaTeX finishes rendering (it renders async into the DOM)
        const observer = new MutationObserver(() => {
          const baseKatex = base.querySelectorAll(".katex").length;
          const markKatex = document.getElementById("tashkil-mark")
            ? document.getElementById("tashkil-mark").querySelectorAll(".katex").length
            : 0;
          if (baseKatex > markKatex) buildMark();
        });
        observer.observe(base, { childList: true, subtree: true });
        setTimeout(() => observer.disconnect(), 5000);
      }

      applyTashkil();
      document.addEventListener("astro:after-swap", function () {
        const main = document.getElementById("main-content");
        if (main) {
          delete main.dataset.tashkil;
          // Unwrap: move base children back to main, remove mark
          const base = document.getElementById("tashkil-base");
          const mark = document.getElementById("tashkil-mark");
          if (base) while (base.firstChild) main.insertBefore(base.firstChild, base);
          base?.remove();
          mark?.remove();
        }
        applyTashkil();
      });
    </script>
  </body>
</html>
