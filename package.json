{
  "name": "david_awad_personal_site",
  "version": "2.4.0",
  "engines": {
    "node": ">=20.11.1"
  },
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "dev": "astro dev --port 4586",
    "check": "astro check --watch",
    "start": "astro dev",
    "build": "rm -rf public && NODE_OPTIONS=--max-old-space-size=8192 astro build && pagefind --site public && jampack ./public",
    "build:search": "astro build --silent && pagefind --site public && cp -r public/pagefind static/pagefind",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "cz": "cz",
    "prepare": "husky install",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@pagefind/default-ui": "^1.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.6",
    "astro-google-analytics": "^1.0.3",
    "caniuse-lite": "^1.0.30001754",
    "dayjs": "^1.11.19",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "katex": "^0.16.22",
    "rehype-katex": "^7.0.1",
    "remark-collapse": "^0.1.2",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "satori": "^0.15.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/react": "^4.4.2",
    "@divriots/jampack": "^0.33.1",
    "@shikijs/transformers": "^3.20.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/katex": "^0.16.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/parser": "^8.34.0",
    "astro-eslint-parser": "^1.2.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.28.0",
    "eslint-plugin-astro": "^1.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "!(*.{png,jpg,jpeg,webp,svg,ico,mp4,txt,gif}), CNAME": [
      "prettier --write"
    ]
  }
}
